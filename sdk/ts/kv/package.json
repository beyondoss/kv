{
  "name": "@beyond.dev/kv",
  "version": "0.1.0-dev",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beyondoss/kv.git"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./next": {
      "import": "./dist/next/index.mjs",
      "types": "./dist/next/index.d.mts"
    },
    "./cache": {
      "import": "./dist/cache.mjs",
      "types": "./dist/cache.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "generate-types": "node scripts/generate-types.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@peculiar/x509": "^2.0.0",
    "@types/node": "^22.0.0",
    "next": "^16.2.4",
    "openapi-typescript": "^7.6.1",
    "oxfmt": "^0.46.0",
    "reflect-metadata": "^0.2.2",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "undici": "^6.25.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "ioredis": "^5.10.1",
    "openapi-fetch": "^0.17.0",
    "std-env": "^3.9.0"
  }
}

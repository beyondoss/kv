{
  "openapi": "3.1.0",
  "info": {
    "title": "beyond/kv",
    "description": "",
    "license": {
      "name": "UNLICENSED",
      "identifier": "UNLICENSED"
    },
    "version": "1"
  },
  "paths": {
    "/v1/kv": {
      "get": {
        "tags": [],
        "operationId": "handle_list",
        "parameters": [
          {
            "name": "ns",
            "in": "query",
            "description": "Namespace 0-15, default 0",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "prefix",
            "in": "query",
            "description": "Filter keys by prefix",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "description": "Pagination cursor from a previous response",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Max keys to return (default 100, max 1000)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Page of keys",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/kv/{key}": {
      "get": {
        "tags": [],
        "operationId": "handle_get",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Key to retrieve",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ns",
            "in": "query",
            "description": "Namespace 0-15, default 0",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Value bytes",
            "content": {
              "application/octet-stream": {}
            }
          },
          "404": {
            "description": "Key not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [],
        "operationId": "handle_put",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Key to set",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ns",
            "in": "query",
            "description": "Namespace 0-15, default 0",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "nx",
            "in": "query",
            "description": "Set only if key does not exist (nx=1)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "xx",
            "in": "query",
            "description": "Set only if key already exists (xx=1)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "ttl",
            "in": "query",
            "description": "TTL seconds (overridden by X-KV-TTL header)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "minimum": 0
            }
          },
          {
            "name": "If-Match",
            "in": "header",
            "description": "Set only if current revision matches",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64",
              "minimum": 0
            }
          },
          {
            "name": "X-KV-KeepTTL",
            "in": "header",
            "description": "Preserve existing TTL (incompatible with TTL options)",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "X-KV-Return-Old",
            "in": "header",
            "description": "Return old value atomically (incompatible with conditional writes)",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/octet-stream": {}
          }
        },
        "responses": {
          "200": {
            "description": "Old value (when X-KV-Return-Old is set and key existed)",
            "content": {
              "application/octet-stream": {}
            }
          },
          "204": {
            "description": "Stored"
          },
          "400": {
            "description": "Conflicting options",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Conflict (NX/XX or revision mismatch)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [],
        "operationId": "handle_delete",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Key to delete",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ns",
            "in": "query",
            "description": "Namespace 0-15, default 0",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "If-Match",
            "in": "header",
            "description": "Delete only if current revision matches",
            "required": false,
            "schema": {
              "type": [
                "integer",
                "null"
              ],
              "format": "int64",
              "minimum": 0
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted (or did not exist)"
          },
          "409": {
            "description": "Revision mismatch",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/kv/{key}/incr": {
      "post": {
        "tags": [],
        "operationId": "handle_incr",
        "parameters": [
          {
            "name": "key",
            "in": "path",
            "description": "Counter key",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "ns",
            "in": "query",
            "description": "Namespace 0-15, default 0",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "minimum": 0
            }
          },
          {
            "name": "delta",
            "in": "query",
            "description": "Increment delta (default 1)",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "New counter value",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncrResponse"
                }
              }
            }
          },
          "400": {
            "description": "Stored value is not an integer or overflowed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "IncrResponse": {
        "type": "object",
        "required": [
          "value"
        ],
        "properties": {
          "value": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "KeyItem": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          }
        }
      },
      "ListResponse": {
        "type": "object",
        "required": [
          "keys",
          "complete"
        ],
        "properties": {
          "complete": {
            "type": "boolean"
          },
          "cursor": {
            "type": [
              "string",
              "null"
            ]
          },
          "keys": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/KeyItem"
            }
          }
        }
      }
    }
  }
}
